{
  "name": "buddy-script-server",
  "version": "1.0.0",
  "description": "This is Buddy-Script-Server. I made it for Appifylab Software Company Task.",
  "keywords": [
    "prisma",
    "express.js",
    "node.js",
    "typescript",
    "postgresql"
  ],
  "homepage": "https://github.com/MdShijanAli/Buddy-Script-Server#readme",
  "bugs": {
    "url": "https://github.com/MdShijanAli/Buddy-Script-Server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MdShijanAli/Buddy-Script-Server.git"
  },
  "license": "ISC",
  "author": "Md Shijan Ali",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "migrate": "npx prisma migrate dev",
    "generate": "npx prisma generate",
    "show:db": "npx prisma studio",
    "backfill:comments-count": "tsx src/script/backfillCommentsCount.ts",
    "generate:auth": "npx @better-auth/cli generate",
    "seed:admin": "tsx src/script/seedAdmin.ts",
    "build": "prisma generate && tsc",
    "build:vercel": "prisma generate && tsup src/index.ts --format esm --platform node --target node20 --outDir api --external pg-native",
    "deploy:vercel": "vercel --prod",
    "postinstall": "prisma generate",
    "reset:db": "npx prisma migrate reset",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/multer": "^2.1.0",
    "axios": "^1.14.0",
    "better-auth": "^1.5.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "prisma": "^7.6.0"
  }
}
